# Template variabile de mediu
# Copiaza in .env si completeaza valorile
# .env NU se commite in git

# ─── Baza de date ─────────────────────────────────────────────────────────────
DB_NAME=seniorwatch
DB_ADMIN_USER=seniorwatch_admin
DB_ADMIN_PASSWORD=SCHIMBA_ACEASTA

DB_APP_USER=sw_app
DB_APP_PASSWORD=SCHIMBA_ACEASTA

# ─── Productie (completat din AWS Console) ────────────────────────────────────
# RDS → seniorwatch-postgres → Connectivity → Endpoint
DB_HOST=seniorwatch-postgres.ckaqkenutyfa.eu-central-1.rds.amazonaws.com
DB_PORT=5432

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genereaza cu: openssl rand -hex 32
JWT_SECRET=INLOCUIESTE_CU_SECRET_ALEATOR

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=eu-central-1
# S3 → Buckets → seniorwatch-reports-31m9
S3_REPORTS_BUCKET=seniorwatch-reports-31m9
# SNS → Topics → seniorwatch-mobile-alerts → ARN
SNS_ALERTS_TOPIC_ARN=arn:aws:sns:eu-central-1:096506568929:seniorwatch-mobile-alerts

# ─── CI/CD (GitHub Actions secrets) ──────────────────────────────────────────
# Adauga in GitHub → Settings → Secrets and variables → Actions:
# AWS_ACCESS_KEY_ID     = <IAM → Users → github-actions → Security credentials>
# AWS_SECRET_ACCESS_KEY = <IAM → Users → github-actions → Security credentials>
# ECR_REPOSITORY_URL    = <ECR → Repositories → seniorwatch-cloud → URI>
# EB_APP_NAME           = seniorwatch-cloud
# EB_ENV_NAME           = seniorwatch-dev
